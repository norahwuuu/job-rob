# Existing project-specific ignore
pipeline-orchestrator/scraper_config.yaml

# Ignore all pipeline artifacts folders at any depth
**/out/
**/artifacts/

# Environment and secrets
**/.env
**/.env.*
**/*secret*
**/*secrets*
**/*token*
**/*tokens*
**/*apikey*
**/*api_key*
**/*credentials*
**/credentials.json
**/secrets.py
**/*.pem
**/*.key
**/*.p12
**/*.pfx

# Privacy-sensitive local state
**/*cookies*.pkl
**/*cookies*.json
**/*session*
**/*history*
**/*linkedin*cookie*
**/*browser*cookie*

# Personal profile and resume files
**/cv.docx
**/cv.pdf
**/resume.json
**/*resume*.docx
**/*resume*.pdf
**/*_Resume_*.docx
**/*_Resume_*.pdf
**/*.docx
**/*.pdf
**/*.DOCX
**/*.PDF
**/*personal*
**/*profile*

# Local logs and temp diagnostics
**/logs/
**/*.log

# Python cache
**/__pycache__/
**/*.pyc
